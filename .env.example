# Nistula Guest Message Handler — Environment Variables
# Copy this file to .env and fill in your actual values

# Claude API Configuration
# Get your API key from the assessment email
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# Database Configuration (PostgreSQL)
# Optional for local development; required for production
DATABASE_URL=postgresql://user:password@localhost:5432/nistula
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=nistula
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Email Configuration (for alerts to managers/caretakers)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=noreply@nistula.com

# WhatsApp Integration (Twilio or similar)
# WHATSAPP_API_KEY=your_key_here
# WHATSAPP_ACCOUNT_SID=your_sid_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/nistula/handler.log

# Feature Flags
ENABLE_PATTERN_DETECTION=true
AUTO_ESCALATE_COMPLAINTS=true
AGENT_REVIEW_TIMEOUT_MINUTES=30
